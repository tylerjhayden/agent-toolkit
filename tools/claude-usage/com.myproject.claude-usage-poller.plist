<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string><your-project-label>.claude-usage-poller</string>

    <key>ProgramArguments</key>
    <array>
        <string><path-to-project>/.claude/tools/claude-usage/claude-usage-poller.sh</string>
    </array>

    <key>StartInterval</key>
    <integer>120</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string><path-to-project>/logs/claude-usage-poller.log</string>

    <key>StandardErrorPath</key>
    <string><path-to-project>/logs/claude-usage-poller-error.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>$HOME/.bun/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>SYSTEM_DIR</key>
        <string><path-to-project></string>
    </dict>

    <key>WorkingDirectory</key>
    <string><path-to-project></string>
</dict>
</plist>
